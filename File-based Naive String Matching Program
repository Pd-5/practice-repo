import time

def function1(txt, pat, m, n):

    for i in range(m-n+1):

        if txt[i:n+i] == pat:
            return i

    return -1


f = open("input1.txt", "r")
f2 = open("pattern.txt", "r")

txt = f.read().strip()
pat = f2.read().strip()

stime = time.time()

print(function1(txt, pat, len(txt), len(pat)))

etime = time.time()

print("Text Length:", len(txt))
print("Pattern Length:", len(pat))
print("Execution Time:", etime-stime)
